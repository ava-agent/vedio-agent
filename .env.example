# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Encryption (required - generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-string

